# Copy to .env and adjust. Docker Compose sets DATABASE_URL inside containers.

DATABASE_URL=postgresql://signal:signal@localhost:5432/signal_lab?schema=public

# Backend (NestJS)
PORT=3001
FRONTEND_ORIGIN=http://localhost:3000

# Frontend (Next.js) — browser calls API on host
NEXT_PUBLIC_API_URL=http://localhost:3001

# Next rewrites /grafana → Grafana UI (browser must reach this host:port)
GRAFANA_BROWSER_ORIGIN=http://localhost:3002

# Sentry (Nest) — leave empty to disable
SENTRY_DSN=

# Log level for JSON scenario logs (pino): silent | fatal | error | warn | info | debug | trace
LOG_LEVEL=info
